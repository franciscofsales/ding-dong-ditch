# Postgres / Nextcloud
POSTGRES_DB=nextcloud
POSTGRES_USER=nextcloud
POSTGRES_PASSWORD=changeme

NEXTCLOUD_ADMIN_USER=admin
NEXTCLOUD_ADMIN_PASSWORD=changeme

# Optional: password-protect the Ring management UI
# Leave empty for no password (local-only use)
#UI_PASSWORD=

# Space-separated list of trusted domains for Nextcloud
# Include your local access and any tunnel domains
NEXTCLOUD_TRUSTED_DOMAINS=localhost nextcloud.yourdomain.com

# If using Cloudflare Tunnel, set your Nextcloud domain here
# so login redirects and URLs work correctly through the tunnel
#NEXTCLOUD_DOMAIN=nextcloud.yourdomain.com

# Optional: Cloudflare Tunnel for remote access
# Create a tunnel at https://one.dash.cloudflare.com -> Networks -> Tunnels
# Configure it to route your domain to http://nextcloud:80
# Then paste the tunnel token here and start with: docker compose --profile tunnel up -d
#CLOUDFLARE_TUNNEL_TOKEN=
